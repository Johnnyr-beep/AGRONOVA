# railway.json — Configuracion de despliegue en Railway para AGRONOVA API (Laravel)
# Railway detecta este archivo y lo usa para el build y el arranque del servicio.
{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "php artisan migrate --force && php artisan db:seed --class=SuperAdminSeeder --force && php artisan serve --host=0.0.0.0 --port=$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
